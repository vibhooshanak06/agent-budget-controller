// schema.prisma
//
// Agent Budget Controller — Database Schema
// Generator: @prisma/client
// Datasource: PostgreSQL
//
// Run `npm run db:generate` after modifying this file.
// Run `npm run db:migrate` to apply changes to the database.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Team ──────────────────────────────────────────────────────────────────────
// A team groups one or more agents under a shared budget envelope.

model Team {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(100)
  budgetLimit Decimal  @default(0) @db.Decimal(12, 6) @map("budget_limit")
  budgetUsed  Decimal  @default(0) @db.Decimal(12, 6) @map("budget_used")
  status      String   @default("active") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  agents Agent[]
  alerts Alert[]

  @@map("teams")
}

// ── Agent ─────────────────────────────────────────────────────────────────────
// An agent represents a single AI workload that consumes LLM tokens.
// Each agent belongs to exactly one team.

model Agent {
  id              String   @id @default(uuid()) @db.Uuid
  teamId          String   @db.Uuid @map("team_id")
  name            String   @db.VarChar(255)
  slug            String   @db.VarChar(100)
  budgetLimit     Decimal  @default(0) @db.Decimal(12, 6) @map("budget_limit")
  budgetUsed      Decimal  @default(0) @db.Decimal(12, 6) @map("budget_used")
  modelPreference String?  @db.VarChar(100) @map("model_preference")
  status          String   @default("active") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  team      Team      @relation(fields: [teamId], references: [id], onDelete: Restrict)
  sessions  Session[]
  usageLogs UsageLog[]
  alerts    Alert[]

  @@unique([teamId, slug])
  @@map("agents")
}

// ── Session ───────────────────────────────────────────────────────────────────
// A session represents a single conversation or task window for an agent.
// Token counts and costs accumulate across all UsageLog entries for the session.

model Session {
  id                    String    @id @default(uuid()) @db.Uuid
  agentId               String    @db.Uuid @map("agent_id")
  status                String    @default("active") @db.VarChar(20)
  totalPromptTokens     Int       @default(0) @map("total_prompt_tokens")
  totalCompletionTokens Int       @default(0) @map("total_completion_tokens")
  totalCost             Decimal   @default(0) @db.Decimal(12, 6) @map("total_cost")
  startedAt             DateTime  @default(now()) @map("started_at") @db.Timestamptz
  endedAt               DateTime? @map("ended_at") @db.Timestamptz
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  agent     Agent      @relation(fields: [agentId], references: [id], onDelete: Restrict)
  usageLogs UsageLog[]

  @@map("sessions")
}

// ── UsageLog ──────────────────────────────────────────────────────────────────
// Immutable record of a single LLM request/response.
// agent_id is denormalised here to support efficient per-agent queries
// without always joining through sessions.

model UsageLog {
  id               String   @id @default(uuid()) @db.Uuid
  sessionId        String   @db.Uuid @map("session_id")
  agentId          String   @db.Uuid @map("agent_id")
  model            String   @db.VarChar(100)
  promptTokens     Int      @default(0) @map("prompt_tokens")
  completionTokens Int      @default(0) @map("completion_tokens")
  totalTokens      Int      @default(0) @map("total_tokens")
  cost             Decimal  @default(0) @db.Decimal(12, 6)
  latencyMs        Int?     @map("latency_ms")
  status           String   @default("success") @db.VarChar(20)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  session Session @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  agent   Agent   @relation(fields: [agentId], references: [id], onDelete: Restrict)

  @@index([agentId, createdAt])
  @@index([sessionId])
  @@map("usage_logs")
}

// ── Alert ─────────────────────────────────────────────────────────────────────
// An alert is generated when a budget threshold is crossed or an anomaly
// is detected. team_id and agent_id are both nullable — an alert can be
// scoped to either level, or both.

model Alert {
  id           String   @id @default(uuid()) @db.Uuid
  teamId       String?  @db.Uuid @map("team_id")
  agentId      String?  @db.Uuid @map("agent_id")
  type         String   @db.VarChar(50)
  severity     String   @default("info") @db.VarChar(20)
  message      String   @db.Text
  acknowledged Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  team  Team?  @relation(fields: [teamId], references: [id], onDelete: SetNull)
  agent Agent? @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([teamId, acknowledged])
  @@index([agentId, acknowledged])
  @@map("alerts")
}
