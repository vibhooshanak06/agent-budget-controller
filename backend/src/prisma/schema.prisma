// schema.prisma — Agent Budget Controller (v2) — SQLite version

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Team ──────────────────────────────────────────────────────────────────────
model Team {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  budgetLimit Float    @default(0) @map("budget_limit")
  budgetUsed  Float    @default(0) @map("budget_used")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  agents Agent[]
  alerts Alert[]

  @@map("teams")
}

// ── Agent ─────────────────────────────────────────────────────────────────────
model Agent {
  id              String   @id @default(uuid())
  teamId          String   @map("team_id")
  name            String
  slug            String
  budgetLimit     Float    @default(0) @map("budget_limit")
  budgetUsed      Float    @default(0) @map("budget_used")
  modelPreference String?  @map("model_preference")
  status          String   @default("active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  team                Team                @relation(fields: [teamId], references: [id], onDelete: Restrict)
  sessions            Session[]
  usageLogs           UsageLog[]
  alerts              Alert[]
  modelSubstitutions  ModelSubstitution[]

  @@unique([teamId, slug])
  @@map("agents")
}

// ── Session ───────────────────────────────────────────────────────────────────
model Session {
  id                    String    @id @default(uuid())
  agentId               String    @map("agent_id")
  status                String    @default("active")
  totalPromptTokens     Int       @default(0) @map("total_prompt_tokens")
  totalCompletionTokens Int       @default(0) @map("total_completion_tokens")
  totalCost             Float     @default(0) @map("total_cost")
  startedAt             DateTime  @default(now()) @map("started_at")
  endedAt               DateTime? @map("ended_at")
  createdAt             DateTime  @default(now()) @map("created_at")

  agent     Agent      @relation(fields: [agentId], references: [id], onDelete: Restrict)
  usageLogs UsageLog[]

  @@map("sessions")
}

// ── UsageLog ──────────────────────────────────────────────────────────────────
model UsageLog {
  id               String   @id @default(uuid())
  sessionId        String   @map("session_id")
  agentId          String   @map("agent_id")
  model            String
  promptTokens     Int      @default(0) @map("prompt_tokens")
  completionTokens Int      @default(0) @map("completion_tokens")
  totalTokens      Int      @default(0) @map("total_tokens")
  cost             Float    @default(0)
  latencyMs        Int?     @map("latency_ms")
  status           String   @default("success")
  createdAt        DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  agent   Agent   @relation(fields: [agentId], references: [id], onDelete: Restrict)

  @@index([agentId, createdAt])
  @@index([sessionId])
  @@map("usage_logs")
}

// ── Alert ─────────────────────────────────────────────────────────────────────
model Alert {
  id           String   @id @default(uuid())
  teamId       String?  @map("team_id")
  agentId      String?  @map("agent_id")
  type         String
  severity     String   @default("info")
  message      String
  acknowledged Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  team  Team?  @relation(fields: [teamId], references: [id], onDelete: SetNull)
  agent Agent? @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([teamId, acknowledged])
  @@index([agentId, acknowledged])
  @@map("alerts")
}

// ── ModelSubstitution ─────────────────────────────────────────────────────────
model ModelSubstitution {
  id             String   @id @default(uuid())
  agentId        String   @map("agent_id")
  sessionId      String?  @map("session_id")
  requestedModel String   @map("requested_model")
  resolvedModel  String   @map("resolved_model")
  reason         String
  utilization    Float    @default(0)
  createdAt      DateTime @default(now()) @map("created_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, createdAt])
  @@map("model_substitutions")
}
