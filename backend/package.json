{
  "name": "agent-budget-controller-backend",
  "version": "1.0.0",
  "description": "Enterprise AI governance proxy — budget controller, token metering, and model routing for LLM agents.",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:generate": "prisma generate --schema=src/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=src/prisma/schema.prisma",
    "db:migrate:prod": "prisma migrate deploy --schema=src/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=src/prisma/schema.prisma",
    "db:seed": "node src/prisma/seed.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "@prisma/client": "5.14.0",
    "compression": "1.7.4",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "helmet": "7.1.0",
    "morgan": "1.10.0",
    "openai": "4.52.0",
    "pino": "9.2.0",
    "pino-http": "10.2.0",
    "pino-pretty": "11.2.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "eslint": "8.57.0",
    "nodemon": "3.1.4",
    "prisma": "5.14.0"
  },
  "keywords": [
    "ai",
    "llm",
    "budget-controller",
    "openai",
    "governance",
    "agent"
  ],
  "license": "MIT"
}