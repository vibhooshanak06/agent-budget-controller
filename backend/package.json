{
  "name": "agent-budget-controller-backend",
  "version": "2.0.0",
  "description": "Enterprise AI governance proxy — budget controller, token metering, model routing, real-time dashboard.",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:generate": "prisma generate --schema=src/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=src/prisma/schema.prisma",
    "db:migrate:prod": "prisma migrate deploy --schema=src/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=src/prisma/schema.prisma",
    "db:seed": "node src/prisma/seed.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest --testPathPattern=unit --runInBand --forceExit",
    "test:integration": "jest --testPathPattern=integration --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/prisma/**",
      "!src/server.js"
    ]
  },
  "dependencies": {
    "@prisma/client": "5.14.0",
    "compression": "1.7.4",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "express-rate-limit": "7.3.1",
    "helmet": "7.1.0",
    "ioredis": "5.3.2",
    "morgan": "1.10.0",
    "node-cron": "3.0.3",
    "openai": "4.52.0",
    "pino": "9.2.0",
    "pino-http": "10.2.0",
    "pino-pretty": "11.2.0",
    "rate-limit-redis": "4.2.0",
    "redis": "4.6.14",
    "socket.io": "4.7.5",
    "uuid": "9.0.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "29.7.0",
    "eslint": "8.57.0",
    "jest": "29.7.0",
    "nodemon": "3.1.4",
    "prisma": "5.14.0",
    "supertest": "7.0.0"
  },
  "license": "MIT"
}